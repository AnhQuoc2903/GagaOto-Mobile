{
  "expo": {
    "name": "gara-mobile",
    "slug": "gara-mobile",
    "version": "1.0.0",
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "garamobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.quocnace29032002.garamobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "20c6b2ce-4522-4945-8bdd-c2bac821715f"
      }
    }
  }
}
